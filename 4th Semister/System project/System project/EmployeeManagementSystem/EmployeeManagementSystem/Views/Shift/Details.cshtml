@model EmployeeManagementSystem.Models.Shift

@{
    ViewBag.Title = "Shift Details";
}

<div class="container mt-4">
    <h2 class="text-center">@ViewBag.Title</h2>

    <div class="card">
        <div class="card-header">
            <h4>Shift Details</h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.ShiftName)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.ShiftName)
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.StartTime)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.StartTime)
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.EndTime)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.EndTime)
                </dd>
            </dl>
        </div>
        <div class="card-footer">
            <p>
                @Html.ActionLink("Edit", "Edit", new { id = Model.ShiftId }, new { @class = "btn btn-warning" }) |
                @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary" })
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
