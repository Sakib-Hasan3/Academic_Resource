@model EmployeeManagementSystem.Models.Payroll

@{
    ViewBag.Title = "Payroll Details";
}

<h2 class="text-center my-4">@ViewBag.Title</h2>

<div class="container">
    <!-- Payroll Detail Card -->
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="card-title mb-0">Payroll Details</h5>
        </div>
        <div class="card-body">

            <dl class="row">
                <!-- Employee Full Name -->
                <dt class="col-sm-3">Employee</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Employee.FullName)</dd>

                <!-- Month -->
                <dt class="col-sm-3">Month</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Month)</dd>

                <!-- Basic Salary -->
                <dt class="col-sm-3">Basic Salary</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.BasicSalary)</dd>

                <!-- Attendance Bonus -->
                <dt class="col-sm-3">Attendance Bonus</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.AttendanceBonus)</dd>

                <!-- Deductions -->
                <dt class="col-sm-3">Deductions</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Deductions)</dd>

                <!-- Generated Date -->
                <dt class="col-sm-3">Generated Date</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.GeneratedDate)</dd>
            </dl>
        </div>
    </div>

    <!-- Action Links -->
    <div class="mt-3">
        <a href="@Url.Action("Edit", new { id = Model.PayrollId })" class="btn btn-warning btn-sm">Edit</a>
        <a href="@Url.Action("Index", "Payroll")" class="btn btn-secondary btn-sm ml-2">Back to List</a>
    </div>
</div>

