@model IEnumerable<EmployeeManagementSystem.Models.Payroll>

@{
    ViewBag.Title = "Payroll Records";
}

<div class="container mt-4">
    <h2 class="text-center">@ViewBag.Title</h2>

    <!-- Create New Button -->
    <p>
        <a href="@Url.Action("Create", "Payroll")" class="btn btn-primary mb-3">Create New Payroll</a>
    </p>

    <!-- Payroll Table -->
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.Employee.FullName)</th>
                <th>@Html.DisplayNameFor(model => model.Month)</th>
                <th>@Html.DisplayNameFor(model => model.BasicSalary)</th>
                <th>@Html.DisplayNameFor(model => model.AttendanceBonus)</th>
                <th>@Html.DisplayNameFor(model => model.Deductions)</th>
                <th>@Html.DisplayNameFor(model => model.GeneratedDate)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Employee.FullName)</td>
                    <td>@Html.DisplayFor(modelItem => item.Month)</td>
                    <td>@Html.DisplayFor(modelItem => item.BasicSalary)</td>
                    <td>@Html.DisplayFor(modelItem => item.AttendanceBonus)</td>
                    <td>@Html.DisplayFor(modelItem => item.Deductions)</td>
                    <td>@Html.DisplayFor(modelItem => item.GeneratedDate)</td>
                    <td>
                        <a href="@Url.Action("Edit", "Payroll", new { id = item.PayrollId })" class="btn btn-warning btn-sm">Edit</a> |
                        <a href="@Url.Action("Details", "Payroll", new { id = item.PayrollId })" class="btn btn-info btn-sm">Details</a> |
                        <a href="@Url.Action("Delete", "Payroll", new { id = item.PayrollId })" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this payroll?')">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Styles {
    <style>
        .table {
            margin-top: 20px;
        }

            .table th, .table td {
                text-align: center;
            }
    </style>
}
